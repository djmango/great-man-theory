{
  "name": "great-man-theory",
  "version": "1.0.0",
  "private": true,
  "description": "An infographic of great lives, measured by age.",
  "scripts": {
    "build": "bun build src/app.ts --outfile app.js --target browser",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bash scripts/dev.sh",
    "deploy": "bun run build && wrangler deploy",
    "pi:build": "pi/scripts/build-image.sh",
    "pi:flash": "pi/scripts/flash-image.sh",
    "pi:secrets": "pi/scripts/with-sops.sh sops pi/secrets.yaml"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "wrangler": "^4"
  }
}
