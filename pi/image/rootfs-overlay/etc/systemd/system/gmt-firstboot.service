[Unit]
Description=Great Man Theory first-boot provisioning
Wants=NetworkManager.service
After=local-fs.target NetworkManager.service
Before=network-online.target gmt-tailscale.service
ConditionPathExists=!/var/lib/gmt/firstboot.done

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/gmt-firstboot

[Install]
WantedBy=multi-user.target
